@model GymMember

@{
    ViewData["Title"] = "Chi tiet hoi vien";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 page-heading">
    <div>
        <h1 class="h3 mb-1">Chi tiet hoi vien</h1>
        <p class="text-muted mb-0">Thong tin day du cua @Model.Name.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Quay lai danh sach</a>
</div>

@if (Model.SessionsLeft == 0)
{
    <div class="alert alert-warning">
        Hoi vien nay da het so buoi con lai.
    </div>
}

<div class="detail-shell">
    <dl class="row mb-0">
        <dt class="col-sm-3">Id</dt>
        <dd class="col-sm-9">@Model.Id</dd>

        <dt class="col-sm-3">Ho ten</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">So dien thoai</dt>
        <dd class="col-sm-9">@Model.Phone</dd>

        <dt class="col-sm-3">Goi tap</dt>
        <dd class="col-sm-9">@Model.PackageName</dd>

        <dt class="col-sm-3">Phi thang</dt>
        <dd class="col-sm-9">@Model.MonthlyFee.ToString("N0") VND</dd>

        <dt class="col-sm-3">So buoi con lai</dt>
        <dd class="col-sm-9">@Model.SessionsLeft</dd>

        <dt class="col-sm-3">Ngay bat dau</dt>
        <dd class="col-sm-9">@Model.StartDate.ToString("dd/MM/yyyy")</dd>
    </dl>
</div>

<div class="mt-3 d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Sua thong tin</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Xoa hoi vien</a>
</div>

@section Scripts {
    <script>
        console.log("Trang chi tiet phong gym da duoc tai");
    </script>
}
